# Copia este archivo como .env y completa tus valores reales.
# NUNCA subas tu archivo .env con claves reales a un repositorio.

# Clave de la API de OpenAI (para analisis/comentarios de señales con IA)
OPENAI_API_KEY=

# Token del bot de Telegram (para enviar avisos de señales)
TELEGRAM_BOT_TOKEN=

# ID del chat de Telegram donde se envian los avisos
TELEGRAM_CHAT_ID=
